{
  "name": "cifence",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub Action wrapper for CIFence.",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.0.8",
  "files": [
    "action.yml",
    "dist/index.js",
    "cmd",
    "internal",
    "go.mod",
    "go.sum",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "format": "prettier --write \"**/*.{md,json,yml,yaml,ts,mjs}\" \"!tests/fixtures/workflows/invalid-yaml.yml\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{md,json,yml,yaml,ts,mjs}\" \"!tests/fixtures/workflows/invalid-yaml.yml\" --ignore-path .gitignore",
    "lint": "node scripts/validate-action-metadata.mjs && node scripts/validate-fixtures.mjs --schema-only",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.js",
    "fixtures": "node scripts/validate-fixtures.mjs",
    "release:dry-run": "node scripts/release-state.mjs",
    "sync:check": "node scripts/sync-repositories.mjs --check"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/github": "9.1.1"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "esbuild": "0.28.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "yaml": "2.8.4"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": false,
    "trailingComma": "all"
  }
}
